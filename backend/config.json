{
  "api": {
    "enabled": true,
    "base_url": "https://live.thefusionapps.com/api/v4/retail/visit-stats",
    "configs": [
      {
        "branchId": "TMJ-CBE",
        "startDate": "2026-05-1",
        "syncStartDate": "2026-05-1",
        "syncEndDate": ""
      }
    ],
    "category": "all",
    "limit": 50,
    "timeRange": "0,300,18000",
    "restart": false,
    "deep_sync": false,
    "syncWindowDays": 3,
    "fetchInterval": 2
  },
  "model": {
    "name": "buffalo_l",
    "threshold": 0.5,
    "quality_filter": {
      "min_blur": 30.0,
      "min_confidence": 0.85,
      "min_face_size": 64
    }
  },
  "qdrant": {
    "collection": "face_embeddings",
    "vector_size": 512,
    "path": "./qdrant_db"
  }
}